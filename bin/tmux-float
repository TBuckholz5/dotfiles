#!/usr/bin/env bash
WIN_IDX="$1"
CALLER_DIR="$2"
SESSION="scratch-$WIN_IDX"
CURRENT="$(tmux display-message -p '#{session_name}')"

if [[ "$CURRENT" == scratch-* ]]; then
    tmux detach-client
    exit 0
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SESSION" -c "$CALLER_DIR"
    tmux set-option -t "$SESSION" status off
fi

tmux popup \
    -w 80% \
    -h 75% \
    -b rounded \
    -d "#{pane_current_path}" \
    -E "tmux attach-session -t '$SESSION'"
