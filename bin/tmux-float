#!/usr/bin/env bash
SESSION_NAME="$1"
CALLER_DIR="$2"
SCRATCH="scratch-$SESSION_NAME"
CURRENT="$(tmux display-message -p '#{session_name}')"

if [[ "$CURRENT" == scratch-* ]]; then
    tmux detach-client
    exit 0
fi

if ! tmux has-session -t "$SCRATCH" 2>/dev/null; then
    tmux new-session -d -s "$SCRATCH" -c "$CALLER_DIR"
    tmux set-option -t "$SCRATCH" status off
fi

tmux popup \
    -w 80% \
    -h 75% \
    -b rounded \
    -d "#{pane_current_path}" \
    -E "tmux attach-session -t '$SCRATCH'"
